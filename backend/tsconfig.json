{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "ignoreDeprecations": "5.0",
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src", "generated"],
  "exclude": ["node_modules", "dist"]
}
